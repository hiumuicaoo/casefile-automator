# Sao chép file này thành `.env` trên server Ubuntu trước khi chạy docker compose up -d
# Lấy giá trị từ Lovable Cloud (Backend) — cả hai biến VITE_* và không VITE_* đều cần.

# ===== Database Local (PostgreSQL) =====
# ⚠️  THAY ĐỔI password này thành một mật khẩu mạnh!
DB_USER=casefile_user
DB_PASSWORD=changeme_secure_password
DB_NAME=casefile_db
# DATABASE_URL sẽ được tự động tạo: postgresql://casefile_user:password@postgres:5432/casefile_db

# ===== Supabase (nếu vẫn sử dụng) =====
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ===== Tailscale =====
# Tạo auth key tại https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
TS_HOSTNAME=giamdinh
